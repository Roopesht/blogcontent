  "steps": [
    {
      "order": 1,
      "instruction": "Fry the pooris.",
      "duration": 15,
      "tips": ["Keep oil at medium heat — too hot makes pooris crisp, too cool makes them oily."],
      "subSteps": [
        "Roll small discs from rested dough.",
        "Deep fry in medium-hot oil until puffed.",
        "Drain and keep them soft (don't over-crisp)."
      ]
    },
    {
      "order": 2,
      "instruction": "Prepare the kheera (flavored milk).",
      "duration": 15,
      "tips": [
        "Stir continuously after adding paste to prevent lumps.",
        "Consistency should be pourable, not thick like kheer."
      ],
      "subSteps": [
        "Lightly warm poppy seeds and sesame (do not over-roast).",
        "Lightly roast dry coconut.",
        "Grind coconut + poppy seeds + sesame + cardamom into a fine paste.",
        "Boil milk and simmer for 5–7 minutes.",
        "Add sugar.",
        "Add ground paste slowly, stirring continuously.",
        "Cook until slightly thick.",
        "Fry cashews and almonds in ghee and add to the milk."
      ]
    },
    {
      "order": 3,
      "instruction": "Assemble and serve.",
      "duration": 2,
      "subSteps": [
        "Slightly press the pooris.",
        "Pour warm kheera over them.",
        "Serve immediately or after light soaking."
      ]
